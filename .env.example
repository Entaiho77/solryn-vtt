# Firebase web app config. Copy to `.env.local` and fill with your project's values.
# Found in Firebase console -> Project settings -> Your apps -> SDK setup and configuration.
# All client Firebase config values are safe to expose in the browser bundle;
# security is enforced by Realtime Database rules, not by hiding these.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to connect to local Firebase emulators (auth + realtime db)
# instead of the live project. See README for `firebase emulators:start`.
VITE_USE_FIREBASE_EMULATOR=false
