  "combat_rules": [
    {
      "name": "Auto-Hit Combat",
      "description": "All attacks in Solryn automatically hit. Damage is determined by weapon and skill.",
      "details": "Instead of rolling to hit, players roll damage directly. Defense is handled through Damage Reduction (DR)."
    },
    {
      "name": "Initiative",
      "description": "Combat turn order determined by Nimbleness Modifier",
      "details": "Add your Nimbleness Modifier to initiative. Ties resolved by comparing base Nimbleness scores."
    },
    {
      "name": "Damage Reduction (DR)",
      "description": "Primary defense mechanic - reduces incoming damage",
      "details": "Total DR = Armor DR + Shield DR + NIM Mod + END Mod. Subtract DR from all incoming damage."
    },
    {
      "name": "Cover",
      "description": "Provides bonus DR and advantage on Stealth",
      "details": "Light Cover: +2 DR, Half Cover: +3 DR, Three-Quarters: +4 DR, Full: Cannot be targeted"
    },
    {
      "name": "Critical Hits",
      "description": "Natural 20 on damage roll or specific abilities",
      "details": "Critical hits ignore DR and deal double maximum damage"
    }
