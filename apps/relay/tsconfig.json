{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    // node10 is the correct resolution for this CommonJS Node build; it is deprecated only in the
    // (future) TS 7 timeline, so silence the forward-looking warning while it still functions.
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["src/__tests__", "dist", "node_modules"]
}
