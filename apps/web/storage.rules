rules_version = '2';

// Map images live under maps/{gameId}/. Any authenticated user may read/write for now
// (consistent with the client-side-filtering MVP); tighten to game membership before
// any high-stakes/public game.
service firebase.storage {
  match /b/{bucket}/o {
    match /maps/{gameId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 12 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
