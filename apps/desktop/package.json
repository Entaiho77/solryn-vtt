{
  "name": "@solryn/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Solryn VTT desktop shell (Electron) — wraps the shared React UI as a native window.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.solryn.vtt",
    "productName": "Solryn VTT",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**"
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
